enum Role {
  user 
  admin
  moderator 
}


generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
}



model User {
  id    Int    @id @default(autoincrement())
  name  String
  email String @unique
  password String? //make optional Temporarily 
  role          Role     @default(user) // ✅ strong typing
  image    String? 
  emailVerified Boolean  @default(false)
  refreshToken  String?
  resetToken    String?
  resetTokenExp DateTime?
  createdAt     DateTime @default(now())
}
